# Open Shine — environment configuration.
# Copy to /etc/open-shine.env (chmod 600, owner root:root) on the server, or to
# a local .env for development. Never commit real secrets.

# --- Database (required) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=<db-user>
DB_PASS=<db-password>
DB_NAME=open_shine

# --- Admin login (seeded on first boot if the account doesn't exist) ---
ADMIN_NAME=Admin
ADMIN_EMAIL=<your-email>
ADMIN_PASSWORD=<a-strong-password>

# --- Cookies / security ---
# true in production (behind HTTPS/Caddy); set false for local plain-HTTP dev.
COOKIE_SECURE=true

# --- Monitoring ---
# Sampling cadence for metric history + threshold/target checks (Go duration).
MONITOR_INTERVAL=60s

# --- Optional: let the Go binary serve the built SPA itself (Caddy normally
# does this). Point at web-front/dist to enable; leave unset for API-only.
# STATIC_DIR=/home/<user>/<workspace>/open_shine/web-front/dist

# --- SMTP (optional; heartbeat + alert emails disabled if unset) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<gmail-address>
SMTP_PASS=<16-char Gmail App Password, NO spaces>
# SMTP_FROM optional; defaults to SMTP_USER
